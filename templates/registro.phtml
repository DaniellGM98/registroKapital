		<script src="<?=URL_ROOT?>/assets/plugins/jquery/jquery.min.js"></script>
		<script src="<?=URL_ROOT?>/assets/plugins/bootstrap/js/bootstrap.min.js"></script>
		<script src="<?=URL_ROOT?>/assets/plugins/blockUI/jquery.blockUI.js"></script>
		<script src="<?=URL_ROOT?>/assets/plugins/sweetalert/sweetalert.min.js"></script>
		<script src="<?=URL_ROOT?>/assets/plugins/md5/md5.min.js"></script>
		<script>
			$(function(){
				const $apiUrl = '<?= URL_ROOT ?>/';
				$(".preloader").fadeOut();

				function showError(message){
					swal({
						type: 'error',
						title: 'Falta información',
						text: message
					});
				}

				$('#reg-apodo').on('blur', function(e){
					e.stopPropagation();
					const $apodo = $('#reg-apodo');
					const $apodoFeedback = $('#reg-apodo-feedback');
					let valor = $.trim($(this).val());
					if(valor != '' && valor.length > 8){
						$apodo.addClass('is-invalid').focus();
						$apodoFeedback.text('Ingresa máximo 8 caracteres.').show();
					}else{
						$apodo.removeClass('is-invalid');
						$apodoFeedback.text('').hide();
					}
				});

				$('#reg-telefono').on('input', function() {
					this.value = this.value.replace(/[^0-9]/g, '');
				});

				$('#reg-telefono').on('blur', function(e){
					e.stopPropagation();
					const $telefono = $('#reg-telefono');
					const $telefonoFeedback = $('#reg-telefono-feedback');
					let valor = $.trim($(this).val());
						valor = valor.replace(/\D/g,'').replace(' ', '');
						if(valor != '' && (valor.length < 10 || valor.length > 10)){
							$telefono.addClass('is-invalid').focus();
							$telefonoFeedback.text('Ingresa un número de WhatsApp válido, debe tener 10 dígitos.').show();
						}else if(valor != ''){
							$.get(`${$apiUrl}registro/validar/telefono/${valor}/`, function(resp){
								if(resp.response){
									$telefono.addClass('is-invalid').focus();
									$telefonoFeedback.text('Este número de WhatsApp ya está registrado.').show();
								}else{
									$telefono.removeClass('is-invalid');
									$telefonoFeedback.text('').hide();
								}
							});
						}else{
							$telefono.removeClass('is-invalid');
							$telefonoFeedback.text('').hide();
						}
				});

				$('#btnSelfie').click(function(){
					$('#reg-selfie').trigger('click');
				});

				$('#reg-selfie').change(function(){
					let file = this.files[0];
					if(file){
						$(this).removeClass('is-invalid');
						let reader = new FileReader();
						reader.onload = function(e){
							$('#foto').attr('src', e.target.result);
							$('#foto').removeClass('d-none');
						}

						reader.readAsDataURL(file);
					}
				});

				$('#btnRegistro').click(function(e){
					e.preventDefault();
					let btn = $(this);
					btn.attr('disabled', true).prop('disabled', true);
					let $data = {};
					let selfie = $('#reg-selfie')[0].files[0] || null;

					$.each($('#frm-registro input'), function (index, elem) { 
						$(elem).removeClass('is-invalid');
						let ide = $(elem).attr('id');
						if(!$(elem).hasClass('dinamico')){
							ide = ide.replace('reg-','');
							let valor = $.trim($(elem).val());
							$data[ide] = valor;
						}
					});

					if($data.nombre == ''){
						$('#reg-nombre').addClass('is-invalid').focus();
						btn.attr('disabled', false).prop('disabled', false);
					}else if($data.apodo == ''){
						$('#reg-apodo').addClass('is-invalid').focus();
						btn.attr('disabled', false).prop('disabled', false);
					}else if($data.puesto == ''){
						$('#reg-puesto').addClass('is-invalid').focus();
						btn.attr('disabled', false).prop('disabled', false);
					}else if($data.sucursal == ''){
						$('#reg-sucursal').addClass('is-invalid').focus();
						btn.attr('disabled', false).prop('disabled', false);
					}else if($data.telefono == ''){
						$('#reg-telefono').addClass('is-invalid').focus();
						btn.attr('disabled', false).prop('disabled', false);
					}else if($data.email == ''){
						$('#reg-email').addClass('is-invalid').focus();
						btn.attr('disabled', false).prop('disabled', false);
					}else if(!selfie){
						$('#reg-selfie').addClass('is-invalid');
						btn.attr('disabled', false).prop('disabled', false);
						showError('Debes seleccionar una selfie para completar tu preregistro.');
					}else{
						let formData = new FormData();
						$.each($data, function(key, value){
							if(key !== 'selfie'){
								formData.append(key, value);
							}
						});

						formData.append('selfie', selfie);
						blockPage();
						$.ajax({
							url: `${$apiUrl}registro/add/`,
							type: 'POST',
							data: formData,
							processData: false,
							contentType: false,
							dataType: 'json'
						}).done(function (resp) {
								if(resp.response){
									$('#message-success').addClass('alert').addClass('alert-success').removeClass('hide');
									$('#frm-registro').slideUp();
									$('#frm-res').slideDown();
									$('html, body').animate({ scrollTop: $("#logo").offset().top }, 1000);
								}else{
									showError(resp.message || 'No fue posible completar el preregistro.');
								}
							}).fail(function (xhr) {
								let resp = xhr.responseJSON || {};
								showError(resp.message || 'Ocurrió un error al enviar la información.');
							}).always(function () {
								$.unblockUI();
								btn.attr('disabled', false).prop('disabled', false);
							});
					}

				});

				function blockPage(){
					$.blockUI({ 
						message: '<div class="spinner-grow text-primary" style="width: 3rem; height: 3rem;" role="status"><span class="sr-only">Loading...</span></div>',
						overlayCSS: {
							backgroundColor: '#1b2024',
							opacity: 0.8,
							zIndex: 1200,
							cursor: 'wait'
						},
						css: {
							border: 0,
							color: '#fff',
							padding: 0,
							zIndex: 1201,
							backgroundColor: 'transparent'
						}
					});
				}
			});
		</script>
	</body>

</html>