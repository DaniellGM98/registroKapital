<?php 

    require_once('../public/core/tcpdf/config/lang/spa.php');
    require_once('../public/core/tcpdf/tcpdf.php');

    class MYPDF extends TCPDF {
        public function Header() {}
        public function Footer() {}
    }

    $pdf = new MYPDF('L', PDF_UNIT, array(100, 50), true, 'UTF-8', false);

    $pdf->SetCreator('www.ddsmedia.net');
    $pdf->SetAuthor('DDS.media');
    $pdf->SetTitle('Gafete Kapital Bank');
    $pdf->SetSubject('');
    $pdf->SetKeywords('');
    $pdf->SetAutoPageBreak(false, 0);
    $pdf->SetFillColor(254, 254, 254);
    
    $pdf->SetMargins(0, 0, 0, false);
    $pdf->SetHeaderMargin(0);
    $pdf->SetFooterMargin(0);
    
    $pdf->setPrintFooter(false);
    $pdf->setPrintHeader(false);
    
    $pdf->AddPage();
    
    $pdf->SetY(2);
    $pdf->SetFont(PDF_FONT_NAME_MAIN, 'B', 27);
    $pdf->MultiCell(0,5, mb_strtoupper($data->apodo, 'UTF-8'), 0, 'C', 0, 1);
    $pdf->SetFont(PDF_FONT_NAME_MAIN, '', 18);
    $pdf->SetY(18);
    $pdf->MultiCell(0,5, mb_strtoupper($data->sucursal, 'UTF-8'), 0, 'C', 0, 1);
    $pdf->Image('../public/data/qr/'.$data->id.'.png', 1, 20, 26);
    $pdf->SetFont(PDF_FONT_NAME_MAIN, '', 15);
    $pdf->SetY(43);
    $pdf->MultiCell(28,5, mb_strtoupper($data->id, 'UTF-8'), 0, 'C', 0, 0);
    $pdf->SetXY(60, 42);
    $pdf->SetFont(PDF_FONT_NAME_MAIN, '', 10);
    $pdf->MultiCell(0,5, mb_strtoupper($data->puesto, 'UTF-8'), 0, '', 0, 0);

    $pdf->Output('F');
    exit();
?>