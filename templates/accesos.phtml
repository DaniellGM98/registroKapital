				cleanTable('tbl-items'); 
				$('#tbl-items tbody').empty();
				createTable('tbl-items', true, null);
			}

			function cleanTable(tbl) {
				if($.fn.dataTable.isDataTable('#'+tbl)) {
					table = $('#'+tbl).DataTable();
					table.destroy();
				}
				$("#nodata").remove();
			}

			function createTable(tbl, paging, arrColumns=null) {
				container = $('<div class="form-inline pull-right" style="overflow: visible"></div>');
				select = $('<select class="selectpicker" multiple data-selected-text-format="static" id="columns-'+tbl+'" title="Mostrar/Ocultar columnas" data-width="fit"></select>').appendTo(container);
				opt = ['acciones','ID','nombre','dia','evento','checkin','estatus'];
				//opt = ['acciones','ID','nombre','dia','estatus'];
				$.each(opt, function (index, value) { 
					select.append('<option class="form-control-sm" value="'+index+'">'+value+'</option>');
				});
				select.selectpicker('val', arrColumns!=null? arrColumns: ['0','1','2','3','4','5','6']);
				//select.selectpicker('val', arrColumns!=null? arrColumns: ['0','1','2','3','4']);
				searchContainer = $('<div class="input-group"></div>').appendTo(container);
				search = $('<input type="text" id="bus" placeholder="Buscar ID o Fecha" class="form-control">').appendTo(searchContainer);
				icon = $('<div class="input-group-append"><span class="input-group-text"><i class="fa fa-search"></i></span></div>').appendTo(searchContainer);

				$('#'+tbl).dataTable({
					scrollX: false,
					paging: paging,
					pagingType: "full_numbers",
					//buttons: [{ extend: 'excelHtml5', autoFilter: true, className: 'btn btn-sm btn-secondary' }],
					//dom: 'RlB<"#toolbar-'+tbl+'">frtip',
					dom: 'Rl<"#toolbar-'+tbl+'">frtip',
					"columnDefs": [
						{"orderable": false, "targets": [0], "className": 'text-center', "data": 'acciones'},
						{"orderable": true, "targets": [1], "visible": ($.inArray("1", select.val())>=0), "className": 'text-center', "data": 'ID'},
						{"orderable": true, "targets": [2], "visible": ($.inArray("2", select.val())>=0), "className": 'nombre', "data": 'nombre'},
						{"orderable": true, "targets": [3], "visible": ($.inArray("3", select.val())>=0), "className": 'text-center', "data": 'dia'},
						{"orderable": true, "targets": [4], "visible": ($.inArray("4", select.val())>=0), "className": 'text-center', "data": 'evento'},
						{"orderable": true, "targets": [5], "visible": ($.inArray("5", select.val())>=0), "className": 'text-center', "data": 'checkin'},
						{"orderable": false, "targets": [6], "visible": ($.inArray("6", select.val())>=0), "className": 'text-center', "data": 'estatus'},
					],
					'order': [[5, 'desc']],
					'lengthMenu': [[20,50,100,200],[20,50,100,200]],
					'processing': true,
					'serverSide': true,
					'ajax': {
						url: $apiUrl+'acceso/getAllRegisAjax/0/0/0',
						type: 'GET',
					},
					createdRow: function(row, data, dataIndex) {
						$(row).attr('data-id', data.id);
					}, 
					drawCallback: function(settings){
						$.unblockUI();
					}
				});

				$('#toolbar-'+tbl).html(container);
				$('#toolbar-'+tbl+' #bus').keyup(function(e) { $("#"+tbl+"_filter label input").val($.trim($(this).val())).trigger('keyup'); });
				$("#toolbar-"+tbl+" #bus").on("search", function(evt) { $("#"+tbl+"_filter label input").val(undefined).trigger('keyup'); });
				$("#toolbar-"+tbl+" #btn-bus").click(function(evt) { evt.preventDefault(); $("#"+tbl+"_filter label input").val($.trim($('#bus').val())).trigger('keyup'); });
				select.on('changed.bs.select', function(e, index) { blockPage();
					column = $('#'+tbl).DataTable().column(index);
					column.visible(!column.visible());
					$.unblockUI();
				});
				$("#"+tbl+"_filter label").hide();
			}

			function getTotalRegist() { 
				$.ajax({ url:$apiUrl+'acceso/totalRegistros/', type:'GET', dataType:'json', }).done(
					function(resp) {
					if(resp.response) {
						$count = resp.result.Total;
					}
					const data = document.querySelector("#counter");
					data.innerHTML = "<span style='color:black'>"+$count+" registros </span style='color:black'>";
					data.textContent;
					//getTotalChecks();
					getItems();
				});
			}

			function getTotalChecks() { 
				$.ajax({ url:$apiUrl+'acceso/totalChecks/', type:'GET', dataType:'json', }).done(
					function(resp) {
					if(resp.response) {
						$count2 = resp.result.Total;
					}
					const data = document.querySelector("#counter2");
					data.innerHTML = "<span style='color:black'>"+$count2+" checkIn</span style='color:black'>";
					data.textContent;
					getItems();
				});
			}
			
			$('#btnRefresh').click(function(){
				$count = 0;
				$count2 = 0;
				getTotalRegist();
			});

			$('#btnExportar').click(function(){
